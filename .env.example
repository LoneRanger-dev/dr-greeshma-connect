# =============================================================================
# Dr. Greeshma Connect — Environment Variables
# Copy this file to .env.local (web) and .env (api) and fill in real values.
# NEVER commit .env files to git.
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE (Supabase PostgreSQL)
# Get from: Supabase Dashboard → Settings → Database → Connection string (pooled)
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# -----------------------------------------------------------------------------
# NEXTAUTH / AUTH.JS (apps/web)
# NEXTAUTH_SECRET: run `openssl rand -base64 32` to generate
# NEXTAUTH_URL: full URL of your web app (http://localhost:3000 in dev)
# -----------------------------------------------------------------------------
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-here-generate-with-openssl-rand-base64-32"

# -----------------------------------------------------------------------------
# GOOGLE OAUTH (for NextAuth Google provider + Calendar/Meet API)
# Create at: https://console.cloud.google.com → APIs & Services → Credentials
# Enable: Google Calendar API, Google Meet API
# Redirect URI: http://localhost:3000/api/auth/callback/google
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Google Calendar / Meet (service account or OAuth2 refresh token for the doctor)
GOOGLE_CALENDAR_ID="primary"
GOOGLE_SERVICE_ACCOUNT_EMAIL="your-service-account@project.iam.gserviceaccount.com"
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# OR: OAuth2 refresh token approach
GOOGLE_REFRESH_TOKEN="your-google-refresh-token"

# -----------------------------------------------------------------------------
# RAZORPAY (payments)
# Get from: https://dashboard.razorpay.com → Settings → API Keys
# Use test keys during development (rzp_test_*)
# -----------------------------------------------------------------------------
RAZORPAY_KEY_ID="rzp_test_your_key_id"
RAZORPAY_KEY_SECRET="your_razorpay_key_secret"
RAZORPAY_WEBHOOK_SECRET="your_razorpay_webhook_secret"
# Exposed to the browser (public)
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_your_key_id"

# -----------------------------------------------------------------------------
# SMTP / EMAIL (Nodemailer)
# For Gmail: enable 2FA and create an App Password
# -----------------------------------------------------------------------------
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-gmail@gmail.com"
SMTP_PASS="your-gmail-app-password"
SMTP_FROM="Dr. Greeshma Connect <your-gmail@gmail.com>"

# -----------------------------------------------------------------------------
# WHATSAPP BUSINESS CLOUD API (Meta)
# Get from: https://developers.facebook.com → WhatsApp → API Setup
# -----------------------------------------------------------------------------
WHATSAPP_TOKEN="your-whatsapp-access-token"
WHATSAPP_PHONE_ID="your-whatsapp-phone-number-id"
WHATSAPP_BUSINESS_ACCOUNT_ID="your-waba-id"
WHATSAPP_VERIFY_TOKEN="your-webhook-verify-token"

# WhatsApp template names (must be approved in Meta Business Manager)
WHATSAPP_TEMPLATE_BOOKING_CONFIRMED="booking_confirmed"
WHATSAPP_TEMPLATE_BOOKING_RESCHEDULED="booking_rescheduled"
WHATSAPP_TEMPLATE_BOOKING_CANCELLED="booking_cancelled"
WHATSAPP_TEMPLATE_REMINDER_24H="appointment_reminder_24h"
WHATSAPP_TEMPLATE_REMINDER_1H="appointment_reminder_1h"

# -----------------------------------------------------------------------------
# SMS FALLBACK (Twilio) — stub, activate when needed
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID="ACyour-twilio-account-sid"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
TWILIO_FROM_NUMBER="+1234567890"

# -----------------------------------------------------------------------------
# BACKEND API (Express)
# -----------------------------------------------------------------------------
PORT="4000"
NODE_ENV="development"
API_BASE_URL="http://localhost:4000"
# Secret for signing JWTs (run `openssl rand -base64 64`)
JWT_ACCESS_SECRET="your-jwt-access-secret"
JWT_REFRESH_SECRET="your-jwt-refresh-secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# -----------------------------------------------------------------------------
# FRONTEND (Next.js) — public vars exposed to browser must start with NEXT_PUBLIC_
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL="http://localhost:4000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Dr. Greeshma Connect"

# -----------------------------------------------------------------------------
# CORS
# Comma-separated list of allowed origins for the Express API
# -----------------------------------------------------------------------------
CORS_ORIGINS="http://localhost:3000"
