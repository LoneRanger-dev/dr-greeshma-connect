# ============================================================
# Dr. Greeshma Connect — API Production Environment Variables
# Copy this file's KEYS to Render's environment settings.
# NEVER commit real values. This file is .gitignored.
# ============================================================

# ── Node ────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000

# ── Database (Supabase) ─────────────────────────────────────
# Pooled connection (pgbouncer) — used at runtime by Prisma.
# Format: postgresql://postgres.<project-ref>:<password>@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL=postgresql://postgres.<PROJECT_REF>:<DB_PASSWORD>@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# Direct (non-pooled) connection — used by prisma migrate deploy.
# Format: postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:<DB_PASSWORD>@db.<PROJECT_REF>.supabase.co:5432/postgres

# ── JWT secrets (generate with: openssl rand -base64 32) ────
JWT_ACCESS_SECRET=<generate-with-openssl>
JWT_REFRESH_SECRET=<generate-with-openssl>
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── CORS (must match your Vercel frontend domain) ───────────
CORS_ORIGINS=https://<your-app>.vercel.app

# ── Google Calendar / OAuth ─────────────────────────────────
GOOGLE_CLIENT_ID=<from-google-console>
GOOGLE_CLIENT_SECRET=<from-google-console>
GOOGLE_CALENDAR_ID=primary
GOOGLE_REDIRECT_URI=https://<render-service>.onrender.com/google/callback
GOOGLE_OAUTH_SUCCESS_URL=https://<your-app>.vercel.app/admin/availability

# ── Razorpay ────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_<key>
RAZORPAY_KEY_SECRET=<secret>
RAZORPAY_WEBHOOK_SECRET=<webhook-secret-from-razorpay-dashboard>

# ── Email (Gmail App Password) ───────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx
SMTP_FROM=Dr. Greeshma Connect <no-reply@your-gmail.com>

# ── WhatsApp (Meta Cloud API) ────────────────────────────────
WHATSAPP_TOKEN=<meta-access-token>
WHATSAPP_PHONE_ID=<phone-number-id>
WHATSAPP_VERIFY_TOKEN=<your-verify-token>
WHATSAPP_TEMPLATE_BOOKING_CONFIRMED=booking_confirmed
WHATSAPP_TEMPLATE_BOOKING_RESCHEDULED=booking_rescheduled
WHATSAPP_TEMPLATE_BOOKING_CANCELLED=booking_cancelled
WHATSAPP_TEMPLATE_REMINDER_24H=appointment_reminder_24h
WHATSAPP_TEMPLATE_REMINDER_1H=appointment_reminder_1h
