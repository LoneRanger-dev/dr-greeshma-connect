# ============================================================
# Dr. Greeshma Connect — Web Production Environment Variables
# Set these in Vercel: Project Settings → Environment Variables
# NEVER commit real values. This file documents keys only.
# ============================================================

# ── NextAuth (Auth.js v5) ────────────────────────────────────
# Your live Vercel domain — used to build OAuth redirect URIs.
# Must NOT have a trailing slash.
NEXTAUTH_URL=https://<your-app>.vercel.app

# Generate with: openssl rand -base64 32
# Third value from Part 1: r+IrRRcyaDU85WV002H9JVxu9RM+59N5JZEc7R18HAc=
NEXTAUTH_SECRET=<generate-with-openssl>

# ── API URLs ─────────────────────────────────────────────────
# NEXT_PUBLIC_ prefix → exposed to the browser (client-side fetch)
# Set to your Render service URL after Part 2 deployment.
NEXT_PUBLIC_API_URL=https://<your-render-service>.onrender.com

# Server-side only (used inside src/auth.ts Credentials provider)
# Should match NEXT_PUBLIC_API_URL but without the NEXT_PUBLIC_ prefix.
API_URL=https://<your-render-service>.onrender.com

# ── Google OAuth ─────────────────────────────────────────────
# Same credentials as the Render backend.
# Authorized redirect URI to add in Google Console:
#   https://<your-app>.vercel.app/api/auth/callback/google
GOOGLE_CLIENT_ID=<from-google-console>
GOOGLE_CLIENT_SECRET=<from-google-console>

# ── Razorpay ─────────────────────────────────────────────────
# No Razorpay env vars needed on Vercel — the API returns keyId
# in the /payments/order response so the frontend never reads it directly.
# Set RAZORPAY_KEY_ID + RAZORPAY_KEY_SECRET + RAZORPAY_WEBHOOK_SECRET on Render.
