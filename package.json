{
  "name": "dr-greeshma-connect",
  "version": "1.0.0",
  "private": true,
  "description": "Dr. Greeshma Connect — Smart Telehealth Booking Platform",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "pnpm --parallel run dev",
    "dev:web": "pnpm --filter web dev",
    "dev:api": "pnpm --filter api dev",
    "build": "pnpm --filter shared build && pnpm --parallel --filter '!shared' build",
    "lint": "pnpm --recursive run lint",
    "typecheck": "pnpm --recursive run typecheck",
    "test": "pnpm --recursive run test",
    "clean": "pnpm --recursive run clean"
  },
  "devDependencies": {
    "typescript": "^5.5.0"
  }
}
